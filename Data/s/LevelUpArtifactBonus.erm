; ===================================== 升级触发逻辑（重制优化：精准经验分段+全流程注释）=====================================
!?FU(OnAfterHeroGainLevel)&i^wog_101_map_rule_15_isEnabled^=(FALSE);
  !!if&i^lv_isGameStarted^;
    !!HE-1:E?(exp:y)/?(level:y); ;读取英雄经验值、等级
    ; 经验分段匹配奖池（适配新等级梯度：1-9/10-19/20-28/29-39/40+）
    !!if&(level)<10; [Lv1-9 → FU(basic_lv_up_bonus)]
      !!FU(basic_lv_up_bonus):P?y3;
    !!en;
    !!if&(level)>=10/(level)<20; [Lv10-19 → FU(advanced_lv_up_bonus)]
      !!FU(advanced_lv_up_bonus):P?y3;
    !!en;
    !!if&(level)>=20/(level)<29; [Lv20-28 → FU(expert_lv_up_bonus)]
      !!FU(expert_lv_up_bonus):P?y3;
    !!en;
    !!if&(level)>=29/(level)<40; [Lv29-39 → FU(master_lv_up_bonus)]
      !!FU(master_lv_up_bonus):P?y3;
    !!en;
    !!if&(level)>=40; [Lv40+ → FU(grand_master_lv_up_bonus)]
      !!FU(grand_master_lv_up_bonus):P?y3;
    !!en;
    !!if&y3>=7; [有效宝物才赠送]
      !!HE-1:A4/y3; ; 装备宝物
      !!HE-1:B0/?z2; ; 读取英雄名称
      !!HE-1:O?y4; ; 读取所属玩家
      !!OW&y4<>-1:Iy4/?y5; ; 判断AI/人类
      !!IF&y4<>-1/y5=0:Q2/8/y3/1/z999; ; 人类玩家弹窗提示
    !!en;
  !!en;
; 升级触发器结束