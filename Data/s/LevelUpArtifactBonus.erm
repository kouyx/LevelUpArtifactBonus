ZVSE2
; ==============================================================================
; Script Name: LevelUpArtifactBonus
; Inspired by: bismarck2 (level-up with artifact bonus idea)
; Author: MoonHeart
; Engine: ERM 2.0+
; Requires: ERA 3.0+, WoG 3.58f+, Advanced Classes Mod v1.094a, Third Upgrade Mod Reborn Mod v1.7.3
; Remake:
; 1. 规则重构：将原「黑名单排除」改为「白名单准入」
; 2. 奖池优化：移除组合宝物和大部分赋能施法/免疫施法宝物；新增FU(grand_master_lv_up_bonus)池，凑齐5个梯度奖池（(basic_lv_up_bonus)~(grand_master_lv_up_bonus)）
; 3. 经验分段：优化等级-经验映射
; 4. 细节补充：每个宝物编号对应完整中文名注释，新增Mod专属宝物适配说明
; 5. 兼容性：完美适配WoG新增宝物、进阶职业套装、三阶升级Mod生物/宝物
; 6. 新增功能：检查英雄是否已拥有随机到的宝物，已拥有则重新随机
; ==============================================================================

!#VRz999:S^^;
!#VRz999:S^恭喜您获得经验与等级的提升，您的士兵向您表达由衷的祝贺，
特此献上一份珍贵的礼物!^;

; ===================================== 全局变量声明 =====================================
; 在游戏开始时设置全局变量，标记游戏已正式开始
; 地图初始设置的高等级英雄不会触发这个标志

!?FU(OnGameEnter);
!!VRi^lv_isGameStarted^:S(TRUE);

; ===================================== 核心宝物池函数（重制优化：白名单准入+检查已有）=====================================
; 奖池规则说明：
; - 所有池随机范围统一为[7,289]（覆盖原版+WoG+Mod所有有效宝物）
; - 仅保留白名单的宝物，其余自动排除
; - 检查英雄是否已拥有随机到的宝物，已拥有则重新随机
; - 奖池严格度梯度：FU(basic_lv_up_bonus)（最严，新手期）→ FU(grand_master_lv_up_bonus)（终局期）

!?FU(basic_lv_up_bonus); [奖池(basic_lv_up_bonus)：白名单准入（新手期基础宝物）]
!!re i/0/99;
  !!VRx1:S7 R289; [初始随机宝物编号：7-289]
  !!HE-1:A2/x1/?(has:y)/?(equipped:y); [检查英雄是否已拥有该宝物]
  !!if&(has)=0/(equipped)=0/x1>=7/x1<=7:; 人马战斧（普通宝物-右手）
    !!br;  [英雄未拥有，跳出循环]
  !!el&(has)=0/(equipped)=0/x1>=13/x1<=13:; 矮人王盾（普通宝物-左手）
    !!br;
  !!el&(has)=0/(equipped)=0/x1>=19/x1<=19:; 神兽之冠（普通宝物-头盔）
    !!br;
  !!el&(has)=0/(equipped)=0/x1>=25/x1<=25:; 藤木甲（普通宝物-盔甲）
    !!br;
  !!el&(has)=0/(equipped)=0/x1>=46/x1<=46:; 幸运三叶草（普通宝物-杂物）
    !!br;
  !!el&(has)=0/(equipped)=0/x1>=48/x1<=49:; 幸运鸟（普通宝物-杂物）、勇气勋章（普通宝物-杂物）
    !!br;
  !!el&(has)=0/(equipped)=0/x1>=52/x1<=54:; 窥镜（普通宝物-杂物）、望远镜（普通宝物-杂物）、亡灵护身符（普通宝物-项链）
    !!br;
  !!el&(has)=0/(equipped)=0/x1>=57/x1<=57:; 抗魔链（普通宝物-项链）
    !!br;
  !!el&(has)=0/(equipped)=0/x1>=60/x1<=60:; 树精灵之弓（普通宝物-杂物）
    !!br;
  !!el&(has)=0/(equipped)=0/x1>=63/x1<=63:; 神目鸟（普通宝物-杂物）
    !!br;
  !!el&(has)=0/(equipped)=0/x1>=66/x1<=66:; 政治家勋章（普通宝物-项链）
    !!br;
  !!el&(has)=0/(equipped)=0/x1>=73/x1<=73:; 魔力护符（普通宝物-杂物）
    !!br;
  !!el&(has)=0/(equipped)=0/x1>=76/x1<=76:; 魔力项圈（普通宝物-项链）
    !!br;
  !!el&(has)=0/(equipped)=0/x1>=84/x1<=85:; 禁锢之灵（普通宝物-杂物）、厄运沙漏（普通宝物-杂物）
    !!br;
  !!el&(has)=0/(equipped)=0/x1>=94/x1<=94:; 活力之戒（普通宝物-戒指）
    !!br;
  !!el&(has)=0/(equipped)=0/x1>=102/x1<=102:; 神圣挂件（普通宝物-项链）
    !!br;
  !!el&(has)=0/(equipped)=0/x1>=107/x1<=107:; 清醒挂件（普通宝物-项链）
    !!br;
  !!el&(has)=0/(equipped)=0/x1>=117/x1<=118:; 黄金包（普通宝物-杂物）、天赐神足（普通宝物-杂物）
    !!br;
  !!el&(has)=0/(equipped)=0/x1>=156/x1<=156:; 战神旗帜（WoG宝物-杂物）
    !!br;
  !!el&(has)=0/(equipped)=0/x1>=185/x1<=189:; 恶魔马蹄铁（三阶升级mod-杂物）、惊骇面具（三阶升级mod-杂物）、压制符文（三阶升级mod-杂物）、压抑之戒（三阶升级mod-戒指）、法力水晶（三阶升级mod-杂物）
    !!br;
  !!el&(has)=0/(equipped)=0/x1>=201/x1<=201:; 电神指环（三阶升级mod-戒指）
    !!br;
  !!el&(has)=0/(equipped)=0/x1>=208/x1<=208:; 精准指环（三阶升级mod-戒指）
    !!br;
  !!el&(has)=0/(equipped)=0/x1>=211/x1<=211:; 箭筒（三阶升级mod-杂物）
    !!br;
  !!el&(has)=0/(equipped)=0/x1>=222/x1<=224:; 妖精地雷（三阶升级mod-杂物）、仪式匕首（三阶升级mod-杂物）、神圣战锤（三阶升级mod-右手）
    !!br;
  !!el&(has)=0/(equipped)=0/x1>=241/x1<=242:; 桶形头盔（三阶升级mod-头盔）、战争指环（三阶升级mod-戒指）
    !!br;
  !!el&(has)=0/(equipped)=0/x1>=251/x1<=251:; 恐惧之戒（三阶升级mod-戒指）
    !!br;
  !!else:; [未命中白名单或英雄已拥有]
    !!if&i=99:; [循环达到上限（最后一次循环）]
      !!VRx1:S85; [厄运沙漏]
      !!br;  [赋值后跳出循环]
    !!en;
    // 非最后一次循环：不操作，继续下一轮随机
  !!en;
!!en;

